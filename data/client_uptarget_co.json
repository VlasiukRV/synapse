[
  {
    "client_id": "client_uptarget_co",
    "form_name": "contact_form",
    "fields": {
      "name": {
        "type": "str",
        "label": "Name",
        "placeholder": "Name",
        "required": true,
        "min_length": 2
      },
      "email": {
        "type": "email",
        "label": "Email",
        "placeholder": "Email",
        "required": true,
        "pattern": "[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,4}$"
      },
      "confirm_email": {
        "type": "str",
        "required": false
      },
      "message": {
        "type": "text",
        "label": "Your message...",
        "placeholder": "Your message...",
        "required": true,
        "max_length": 5000
      }
    },
    "flow": [
      {
        "action": "db_save",
        "params": {
          "target": "json"
        }
      },
      {
        "action": "email_send",
        "params": {
          "template": "uptarget_co_careers_contact_form_email.html",
          "to": "roman.vlasiuk@uptarget.net",
          "subject": "[Uptarget Contact] New Lead"
        }
      }
    ]
  },
  {
    "form_name": "careers_contact_form",
    "title": "Apply for Position",
    "fields": {
      "vacancy_title": {
        "type": "str",
        "label": "Applied Position",
        "required": true,
        "hidden": true
      },
      "name": {
        "type": "str",
        "label": "Name",
        "placeholder": "Name",
        "required": true,
        "min_length": 2
      },
      "email": {
        "type": "email",
        "label": "Email",
        "placeholder": "Email",
        "required": true,
        "pattern": "[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,4}$"
      },
      "confirm_email": {
        "type": "str",
        "required": false
      },
      "resume_link": {
        "type": "str",
        "label": "Link to Resume",
        "placeholder": "Link to Resume"
      },
      "message": {
        "type": "text",
        "label": "Your message...",
        "placeholder": "Your message...",
        "required": true,
        "max_length": 5000
      }
    },
    "flow": [
      {
        "action": "db_save",
        "params": {
          "target": "json"
        }
      },
      {
        "action": "email_send",
        "params": {
          "template": "uptarget_co_careers_contact_form_email.html",
          "to": "roman.vlasiuk@uptarget.net",
          "subject": "[Uptarget Careers] New Lead"
        }
      }
    ]
  }
]